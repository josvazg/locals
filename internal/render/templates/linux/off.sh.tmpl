#!/usr/bin/env bash
set -Eeuo pipefail
LOCALS_DIR="{{.LocalsDir}}"

# --- remove locals DNS ---
DNS_PID_FILE="${LOCALS_DIR}/dns.pid"
# This restores the original /etc/resolv.conf immediately
if mountpoint -q /etc/resolv.conf; then
    sudo umount /etc/resolv.conf
    echo "🔓 Unmounted /etc/resolv.conf"
else
    echo "ℹ️ /etc/resolv.conf was not mounted."
fi
sudo rm -f /etc/systemd/resolved.conf.d/locals.conf

if [ -f "$DNS_PID_FILE" ]; then
    DNS_PID=$(cat "$DNS_PID_FILE")
    if kill -0 "$DNS_PID" 2>/dev/null; then
        kill "$DNS_PID"
        sleep 0.5
        if kill -0 "$DNS_PID" 2>/dev/null; then
            sudo kill -9 "$DNS_PID"
        fi

        echo "🛑 Terminated locals dns (PID: $DNS_PID)"
    else
        echo "⚠️ PID file exists but process $DNS_PID is already dead."
    fi
    rm "$DNS_PID_FILE"
else
    echo "ℹ️ No DNS PID file found. Nothing to kill."
fi

# --- deactivate locals web proxy ---
WEB_PID_FILE="$HOME/.config/locals/web.pid"

if [ -f "$WEB_PID_FILE" ]; then
    WEB_PID=$(cat "$WEB_PID_FILE")
    if kill -0 "$WEB_PID" 2>/dev/null; then
        kill "$WEB_PID"
        echo "🛑 Stopped web process (PID: $WEB_PID)"
    else
        echo "⚠️ Web proxy was not running (stale PID file)."
    fi
    rm "$WEB_PID_FILE"
else
    echo "ℹ️ No web proxy PID file found."
fi

# --- disable mkcerts ---
mkcert -uninstall
